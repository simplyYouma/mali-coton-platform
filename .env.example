# Mode API : 'mock' (défaut) → MSW intercepte tout, ou 'live' → backend réel.
VITE_API_MODE=mock

# Base URL du backend en mode live (ignoré en mock).
# Le suffixe /api est ajouté automatiquement.
VITE_API_BASE_URL=http://187.127.225.182

# Pour basculer en live, créer un .env.local avec :
#   VITE_API_MODE=live
#   VITE_API_BASE_URL=http://187.127.225.182
